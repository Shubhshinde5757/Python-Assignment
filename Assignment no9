# 2 Function ChkGreater() accepts two numbers and prints the greater number
def ChkGreater(no1, no2):
    if no1 > no2:
        print(no1, "is greater")
    else:
        print(no2, "is greater")

def main():
    a = int(input("Enter first number: "))
    b = int(input("Enter second number: "))
    ChkGreater(a, b)

if __name__ == "__main__":
    main()

# 3. Accept one number and print its square
def Square(no):
    print("Square =", no * no)

def main():
    num = int(input("Enter a number: "))
    Square(num)

if __name__ == "__main__":
    main()


