# 5. Check whether a number is divisible by both 3 and 5
def ChkDivisible(no):
    if no % 3 == 0 and no % 5 == 0:
        print("Divisible by 3 and 5")
    else:
        print("Not divisible by 3 and 5")

def main():
    num = int(input("Enter a number: "))
    ChkDivisible(num)

if __name__ == "__main__":
    main()



