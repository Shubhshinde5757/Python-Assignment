# Q1. Write a lambda function using map() which accepts a list of numbers and returns a list of squares of each number.

numbers = list(map(int, input("Enter numbers separated by space: ").split()))

square = list(map(lambda x: x**2, numbers))

print("Original List :", numbers)
print("Square List   :", square)

# Q2. Write a lambda function using filter() which accepts a list of numbers and returns a list of even numbers.

numbers = list(map(int, input("Enter numbers separated by space: ").split()))

even = list(filter(lambda x: x % 2 == 0, numbers))

print("Original List :", numbers)
print("Even Numbers  :", even)


# Q3. Write a lambda function using filter() which accepts a list of numbers and returns a list of odd numbers.

numbers = list(map(int, input("Enter numbers separated by space: ").split()))

odd = list(filter(lambda x: x % 2 != 0, numbers))

print("Original List :", numbers)
print("Odd Numbers   :", odd)


# Q4. Write a lambda function using reduce() which accepts a list of numbers and returns the addition of all elements.

from functools import reduce

numbers = list(map(int, input("Enter numbers separated by space: ").split()))

total = reduce(lambda x, y: x + y, numbers)

print("Original List :", numbers)
print("Sum =", total)


# Q5. Write a lambda function using reduce() which accepts a list of numbers and returns the maximum element.

from functools import reduce

numbers = list(map(int, input("Enter numbers separated by space: ").split()))

maximum = reduce(lambda x, y: x if x > y else y, numbers)

print("Original List :", numbers)
print("Maximum =", maximum)


