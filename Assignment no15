# Q7. Write a lambda function using filter() which accepts a list of strings and returns a list of strings having length greater than 5.

words = input("Enter words separated by space: ").split()

result = list(filter(lambda x: len(x) > 5, words))

print("Original List :", words)
print("Strings with length > 5 :", result)


# Q8. Write a lambda function using filter() which accepts a list of numbers and returns a list of numbers divisible by both 3 and 5.

numbers = list(map(int, input("Enter numbers separated by space: ").split()))

result = list(filter(lambda x: x % 3 == 0 and x % 5 == 0, numbers))

print("Original List :", numbers)
print("Numbers divisible by 3 and 5 :", result)


